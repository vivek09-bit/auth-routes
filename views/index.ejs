<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title %>
    </title>
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            background: #f5f7fa;
            color: #333;
            text-align: center;
            padding: 2rem;
        }

        .card {
            max-width: 520px;
            margin: 1rem auto;
            background: white;
            padding: 1.5rem;
            border-radius: 8px;
            box-shadow: 0 0 20px rgba(30, 30, 60, .08);
        }
    </style>
</head>

<body>
    <div class="card">
        <h1>
            <%= title %>
        </h1>
        <p>
            <%= message %>
        </p>
        <p>API route: <code>/api/auth</code></p>
        <p>Now you can use EJS views and ES6 code in this project.</p>
    </div>
</body>

</html>